parameters:
	ignoreErrors:
		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$bulk_handler\.$#'
			identifier: property.notFound
			count: 1
			path: src/Jobs/SendMessageJob.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$message_count\.$#'
			identifier: property.notFound
			count: 1
			path: src/Jobs/SendMessageJob.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$receiver\.$#'
			identifier: property.notFound
			count: 1
			path: src/Jobs/SendMessageJob.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$receiver_id\.$#'
			identifier: property.notFound
			count: 2
			path: src/Jobs/SendMessageJob.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$receiver_type\.$#'
			identifier: property.notFound
			count: 1
			path: src/Jobs/SendMessageJob.php

		-
			message: '#^PHPDoc tag @var with type Illuminate\\Mail\\Message is not subtype of native type Symfony\\Component\\Mime\\Email\.$#'
			identifier: varTag.nativeType
			count: 1
			path: src/Listeners/AddBccToEmailsListener.php

		-
			message: '#^Negated boolean expression is always false\.$#'
			identifier: booleanNot.alwaysFalse
			count: 1
